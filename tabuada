programa
{
	
	funcao inicio()
	{
		cadeia nome
		real peso, altura, IMC

		escreva("Digite seu nome: ")
		leia (nome)

		escreva("Digite seu peso: ")
		leia(peso)

		escreva("Digite sua altura: ")
		leia(altura)

		IMC = peso / (altura*altura)

		se (IMC <=18)
		{
			escreva("Está abaixo do peso")
		}
		senao
		 se (IMC > 18 e IMC >=24)
		{
			escreva("Está acima do peso")
		}
	}
}
